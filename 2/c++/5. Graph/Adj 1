#include <iostream>
using namespace std;

int main() {
    int matrix [3][3] =
    {
        {0,1,0},
        {1,0,1},
        {0,1,0}
    };
    
    cout << "Matrix: \n";
    
    for(int i = 0; i<3 ; i++){
        for(int j = 0; j<3; j++){
             cout << matrix[i][j] << " ";
        }
        cout<<endl;
    }
    return 0;
}
