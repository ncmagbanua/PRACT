#include <iostream>
using namespace std;

class Stack {
private:
    static const int MAX = 5;
    int arr[MAX];
    int top;

public:
    Stack() {
        top = -1;
    }

    bool isEmpty() {
        return top == -1;
    }

    bool isFull() {
        return top == MAX - 1;
    }

    void push(int value) {
        if (isFull()) {
            cout << "Stack Overflow." << endl;
            return;
        }
        arr[++top] = value;
    }

    int pop() {
        if (isEmpty()) {
            cout << "Stack Underflow." << endl;
            return -1;
        }
        return arr[top--];
    }
};

int main() {
    Stack s;

    cout << "Enter 5 numbers:\n";

    for (int i = 0; i < 5; i++) {
        int num;
        cin >> num;
        s.push(num);
    }

    int sum = 0;

    while (!s.isEmpty()) {
        sum += s.pop();
    }

    cout << "Sum = " << sum << endl;

    return 0;
}
