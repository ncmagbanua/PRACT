#include <iostream>
using namespace std;

const int MAX = 100;

int main()
{
    int graph[MAX][MAX];
    int size;

    cout << "Enter size: ";
    cin >> size;

    if(size <= 0 || size > MAX)
    {
        cout << "Invalid size!";
        return 0;
    }

    cout << "\nEnter the adjacency matrix:\n";

    for(int i = 0; i < size; i++)
    {
        for(int j = 0; j < size; j++)
        {
            cout << "graph[" << i << "][" << j << "] = ";
            cin >> graph[i][j];
        }
    }

    cout << "\nAdjacency Matrix:\n";

    for(int i = 0; i < size; i++)
    {
        for(int j = 0; j < size; j++)
        {
            cout << graph[i][j] << " ";
        }
        cout << endl;
    }

    return 0;
}
